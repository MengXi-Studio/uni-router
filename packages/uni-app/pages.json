{
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "Uni Router Demo",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/guards/index",
			"style": {
				"navigationBarTitleText": "路由守卫"
			}
		},
		{
			"path": "pages/about/index",
			"style": {
				"navigationBarTitleText": "关于"
			}
		},
		{
			"path": "pages/protected/index",
			"style": {
				"navigationBarTitleText": "受保护页面",
				"requireAuth": true
			}
		},
		{
			"path": "pages/login/index",
			"style": {
				"navigationBarTitleText": "登录"
			}
		},
		{
			"path": "pages/event-channel/index",
			"style": {
				"navigationBarTitleText": "页面间通信"
			}
		},
		{
			"path": "pages/composable/index",
			"style": {
				"navigationBarTitleText": "组合式 API"
			}
		},
		{
			"path": "pages/error/index",
			"style": {
				"navigationBarTitleText": "错误处理"
			}
		}
	],
	"easycom": {
		"autoscan": true,
		"custom": {
			"^RouterLink$": "@/uni_modules/mxuni-router-v2/components/router-link/router-link.vue",
			"^TabBar$": "@/uni_modules/mxuni-router-v2/components/tab-bar/tab-bar.vue",
			"^TabBarItem$": "@/uni_modules/mxuni-router-v2/components/tab-bar-item/tab-bar-item.vue"
		}
	}
}
