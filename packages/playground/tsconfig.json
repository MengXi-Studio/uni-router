{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["ESNext", "DOM"],
		"jsx": "preserve",
		"esModuleInterop": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": ["@dcloudio/types"]
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"],
	"exclude": ["node_modules", "dist", "unpackage"]
}
